# PostgreSQL connection (Docker default: port 5434)
DATABASE_URL="postgresql://promed:promed@localhost:5434/promed_admin"

# Session signing secret (generate a long random string for production)
AUTH_SECRET="change-me-to-a-long-random-string"

# Default app login after `npm run db:seed`:
#   Email: admin@promed.com
#   Password: admin123
